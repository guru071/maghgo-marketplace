PORT=4000
NODE_ENV=development

# WhatsApp Cloud API
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WEBHOOK_VERIFY_TOKEN=your_strong_webhook_verify_token
WHATSAPP_APP_SECRET=your_app_secret_here

# Meta (Instagram / Messenger)
META_PAGE_ACCESS_TOKEN=your_page_access_token_here

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Razorpay (PLATFORM account — used for merchant subscription payments to you.
# Shops connect their OWN Razorpay in the dashboard for customer order payments.)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Optional 32-byte hex key (64 chars) to encrypt shops' stored Razorpay secrets
# at rest. If unset, a key is derived from JWT_SECRET. Generate: openssl rand -hex 32
PAYMENTS_ENCRYPTION_KEY=

# Optional. When 'true', the Instagram bot only replies to users who follow you.
REQUIRE_INSTAGRAM_FOLLOW=false

# Remove.bg
REMOVEBG_API_KEY=your_removebg_api_key

# Auth — REQUIRED. Use a strong random value (>= 32 chars), e.g. `openssl rand -hex 32`
JWT_SECRET=your_strong_random_jwt_secret_at_least_32_chars

# Frontend URLs
FRONTEND_URL=http://localhost:3000
REVALIDATION_SECRET=your_revalidation_secret

# Twilio (Optional)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Error Tracking (Optional)
SENTRY_DSN=your_sentry_dsn

# Optional: an APPROVED WhatsApp utility template (body = single {{1}}) used to
# deliver notifications outside the free 24-hour reply window (billed by Meta,
# ~Rs 0.12/msg in India). Create it in WhatsApp Manager -> Message templates.
WHATSAPP_TEMPLATE_ORDER_UPDATE=
WHATSAPP_TEMPLATE_LANG=en
# Background removal: 'removebg' (paid API, default) or 'local' (free on-server
# AI; needs `npm i @imgly/background-removal-node` and ~2GB RAM; falls back to
# remove.bg automatically if unavailable).
BG_REMOVAL_PROVIDER=removebg

# Telegram bot (optional channel — create via @BotFather, then set the webhook:
# curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://<backend>/webhook/telegram&secret_token=<SECRET>")
# This backend's public URL — needed for shops' own Telegram bots (webhooks).
# Optional on Render: RENDER_EXTERNAL_URL is injected automatically and used as
# a fallback. Set this only when hosting elsewhere, or behind your own domain.
# Must be a bare https:// origin — no trailing slash, no path.
BACKEND_PUBLIC_URL=https://your-backend.onrender.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
