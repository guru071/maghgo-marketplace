# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Server-side only. Never referenced from a client component.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Backend API ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── ISR revalidation ────────────────────────────────────────────────────────
# MUST be identical to REVALIDATION_SECRET in backend/.env, or the backend's
# revalidation calls are rejected and product updates are delayed by the
# 60s ISR window. Generate with: openssl rand -hex 32
REVALIDATION_SECRET=generate_with_openssl_rand_hex_32

# ── Admin panel (/goatech-admin-hq) ─────────────────────────────────────────
# Basic-auth credentials. The admin area returns 403 until BOTH are set.
# Use a strong password: this panel edits pricing and reads merchant data.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=generate_a_strong_password

# ── Customer contact channels ───────────────────────────────────────────────
# These drive every "Continue with WhatsApp / Instagram / Messenger / SMS"
# button on the landing, login and register pages.
#
# Leave BLANK if a channel isn't live yet — the button is hidden. Do NOT put a
# placeholder here: a wrong number silently sends every signup to an account
# you don't own, and the app cannot detect that.
#
# WhatsApp: full international number, no '+' and no spaces (e.g. 919876543210)
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Instagram: the handle only, no '@'
NEXT_PUBLIC_INSTAGRAM_HANDLE=
# Messenger: your Facebook page username or numeric page id
NEXT_PUBLIC_MESSENGER_PAGE=
# SMS: full international number, no '+' (Twilio number)
NEXT_PUBLIC_SMS_NUMBER=
# Telegram: the bot's username from @BotFather, without '@' (e.g. MaghgoBot).
# Leave blank to hide the Telegram option.
NEXT_PUBLIC_TELEGRAM_BOT=
